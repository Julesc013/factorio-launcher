{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/factorio-launcher/schemas/factorio.install-ref.schema.json",
  "title": "Factorio Install Reference",
  "type": "object",
  "required": ["install_id", "product_id", "source", "ownership", "executable", "app_dir", "verification"],
  "properties": {
    "install_id": { "type": "string" },
    "product_id": { "const": "factorio" },
    "source": { "type": "string" },
    "ownership": { "enum": ["managed", "foreign", "imported", "portable"] },
    "version": { "type": ["string", "null"] },
    "channel": { "type": ["string", "null"] },
    "platform": { "type": "string" },
    "executable": { "type": "string" },
    "app_dir": { "type": "string" },
    "capabilities": { "type": "array", "items": { "type": "string" } },
    "verification": { "type": "object" }
  },
  "additionalProperties": true
}

