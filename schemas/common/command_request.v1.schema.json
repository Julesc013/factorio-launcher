{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/factorio-launcher/schemas/common/command_request.v1.schema.json",
  "title": "Command Request",
  "type": "object",
  "required": ["schema_version", "command_name", "payload", "dry_run"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "command_name": { "type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$" },
    "payload": { "type": "object" },
    "dry_run": { "type": "boolean" }
  },
  "additionalProperties": false
}
