{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIDE Release Provenance",
  "type": "object",
  "required": [
    "schema_version",
    "source_repo",
    "source_commit",
    "source_branch",
    "dirty_state",
    "export_pack_manifest_sha256",
    "export_pack_checksums_sha256",
    "generated_at_or_source_ref",
    "generated_by",
    "artifact_hashes",
    "preview_only",
    "no_publish"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "source_repo": {"type": "string"},
    "source_commit": {"type": "string"},
    "source_branch": {"type": "string"},
    "dirty_state": {"type": "boolean"},
    "export_pack_manifest_sha256": {"type": "string"},
    "export_pack_checksums_sha256": {"type": "string"},
    "generated_at_or_source_ref": {"type": "string"},
    "generated_by": {"type": "string"},
    "artifact_hashes": {"type": "object"},
    "preview_only": {"type": "boolean"},
    "no_publish": {"type": "boolean"}
  },
  "additionalProperties": true
}
