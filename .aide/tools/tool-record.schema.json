{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AIDE Tool Record",
  "type": "object",
  "required": [
    "tool_id",
    "path",
    "name",
    "kind",
    "language_or_format",
    "executable_hint",
    "command_hint",
    "capability_families",
    "owner",
    "status",
    "evidence_refs",
    "docs_refs",
    "tests_refs",
    "risk_class",
    "recommended_fate",
    "reasons",
    "execution_allowed",
    "apply_allowed"
  ],
  "properties": {
    "tool_id": {"type": "string"},
    "path": {"type": "string"},
    "name": {"type": "string"},
    "kind": {"type": "string"},
    "language_or_format": {"type": "string"},
    "executable_hint": {"type": "boolean"},
    "command_hint": {"type": "string"},
    "capability_families": {"type": "array", "items": {"type": "string"}},
    "owner": {"type": "string"},
    "status": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "docs_refs": {"type": "array", "items": {"type": "string"}},
    "tests_refs": {"type": "array", "items": {"type": "string"}},
    "risk_class": {"type": "string"},
    "recommended_fate": {"type": "string"},
    "reasons": {"type": "array", "items": {"type": "string"}},
    "execution_allowed": {"type": "boolean"},
    "apply_allowed": {"type": "boolean"}
  }
}
