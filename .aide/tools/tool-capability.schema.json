{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AIDE Tool Capability",
  "type": "object",
  "required": ["tool_id", "path", "capability_family", "confidence", "reasons", "execution_allowed"],
  "properties": {
    "tool_id": {"type": "string"},
    "path": {"type": "string"},
    "capability_family": {"type": "string"},
    "confidence": {"type": "string"},
    "reasons": {"type": "array", "items": {"type": "string"}},
    "execution_allowed": {"type": "boolean"}
  }
}
