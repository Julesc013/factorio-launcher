{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "branch": {"type": "string"},
    "commit": {"type": "string"},
    "generated_by": {"type": "string"},
    "repo": {"type": "string"},
    "schema_version": {"type": "string"},
    "tests": {"type": "array"},
    "warnings": {"type": "array"}
  },
  "required": ["schema_version", "repo", "commit", "branch", "generated_by", "tests", "warnings"],
  "type": "object"
}
