{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/factorio-launcher/contracts/schema/ui/frontend_command_surface.v1.schema.json",
  "title": "FacMan Frontend Command Surface",
  "type": "object",
  "required": ["schema", "required_commands", "optional_commands", "unavailable_commands", "frontends"],
  "properties": {
    "schema": { "const": "facman.frontend_command_surface.v1" },
    "required_commands": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "optional_commands": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "unavailable_commands": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "frontends": {
      "type": "array",
      "items": { "$ref": "frontend_capabilities.v1.schema.json" },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
