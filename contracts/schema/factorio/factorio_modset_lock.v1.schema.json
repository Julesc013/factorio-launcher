{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/factorio-launcher/contracts/schema/factorio/factorio_modset_lock.v1.schema.json",
  "title": "Factorio Modset Lockfile",
  "type": "object",
  "required": ["lockfile_version", "factorio_version", "mods"],
  "properties": {
    "lockfile_version": { "type": "integer", "minimum": 1 },
    "factorio_version": { "type": "string" },
    "mods": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "enabled", "source"],
        "properties": {
          "name": { "type": "string" },
          "title": { "type": "string" },
          "version": { "type": "string" },
          "factorio_version": { "type": "string" },
          "enabled": { "type": "boolean" },
          "source": { "type": "string" },
          "file_name": { "type": ["string", "null"] },
          "sha1": { "type": ["string", "null"] },
          "sha256": { "type": ["string", "null"] },
          "dependencies": { "$ref": "#/$defs/dependency_array" },
          "optional_dependencies": { "$ref": "#/$defs/dependency_array" },
          "incompatibilities": { "$ref": "#/$defs/dependency_array" },
          "cache_ref": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "dependency_array": {
      "type": "array",
      "items": { "$ref": "#/$defs/dependency" }
    },
    "dependency": {
      "type": "object",
      "required": ["kind", "name", "operator", "version"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["required", "optional", "hidden_optional", "incompatible"]
        },
        "name": { "type": "string" },
        "operator": { "type": "string" },
        "version": { "type": "string" },
        "raw": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
