  "properties": {
    "schema": {"const": "factorio.snapshot_diff.v1"}, "command": {"const": "snapshots.diff"}, "status": {"const": "ok"},
    "instance_id": {"type": "string"}, "left_snapshot_id": {"type": "string"}, "right_snapshot_id": {"type": "string"},
