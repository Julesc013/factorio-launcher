{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/factorio-launcher/contracts/schema/factorio/factorio_install_reconciliation_plan.v1.schema.json",
  "title": "Factorio Installation Reconciliation Plan",
  "type": "object",
  "required": ["schema", "command", "plan_id", "mode", "mutation_executed", "apply_available", "current_evidence", "desired_state", "steps", "blockers", "risks", "summary", "authority", "rollback"],
  "properties": {
    "schema": { "const": "factorio.install_reconciliation_plan.v1" },
    "command": { "const": "installs.reconcile.plan" },
    "plan_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "mode": { "const": "plan_only" },
    "mutation_executed": { "const": false },
    "apply_available": { "const": false },
    "current_evidence": { "type": "object" },
    "desired_state": { "type": "object" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "status", "owner", "effect", "reason"],
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" },
          "owner": { "type": "string" },
          "effect": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "summary": {
      "type": "object",
      "required": ["status", "change_count", "blocker_count"],
      "properties": {
        "status": { "enum": ["blocked_plan", "already_reconciled", "plan_ready_for_provider_review"] },
        "change_count": { "type": "integer", "minimum": 0 },
        "blocker_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["management_class", "planning_authority", "mutation_owner", "apply_available", "mutation_authority_inferred"],
      "properties": {
        "management_class": { "type": "string" },
        "planning_authority": { "const": "facman_read_only" },
        "mutation_owner": { "const": "universal_setup" },
        "apply_available": { "const": false },
        "mutation_authority_inferred": { "const": false }
      },
      "additionalProperties": false
    },
    "rollback": {
      "type": "object",
      "required": ["strategy", "required", "source_deletion_allowed", "acceptance"],
      "properties": {
        "strategy": { "const": "side_by_side_switch_with_retained_original" },
        "required": { "type": "boolean" },
        "source_deletion_allowed": { "const": false },
        "acceptance": { "const": "human_review_required_before_retirement" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
