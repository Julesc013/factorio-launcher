{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/factorio-launcher/contracts/schema/factorio/factorio_server_plan.v1.schema.json",
  "title": "Non-executing Server Planning Report",
  "type": "object",
  "required": ["schema", "command", "status", "process_started", "network_socket_opened", "firewall_changed", "mutation_executed"],
  "properties": {
    "schema": { "enum": ["factorio.server_plan.v1", "factorio.server_profile_report.v1", "factorio.server_diff.v1"] },
    "command": { "enum": ["servers.inspect", "servers.validate", "servers.plan", "servers.diff"] }, "status": { "const": "ok" },
    "profile": { "type": "object" }, "left": { "type": "object" }, "right": { "type": "object" },
    "differences": { "type": "array" }, "server_settings": { "type": ["object", "null"] },
    "map_generation_settings": { "type": ["object", "null"] }, "map_settings": { "type": ["object", "null"] },
    "effective_launch_plan": { "type": "object" }, "required_input_files": { "type": "array" },
    "expected_output_roots": { "type": "array" }, "port": { "type": "integer" }, "effects": { "type": "array" },
    "risks": { "type": "array" }, "preflight": { "type": "object" },
    "process_started": { "const": false }, "network_socket_opened": { "const": false },
    "firewall_changed": { "const": false }, "mutation_executed": { "const": false }
  },
  "additionalProperties": false
}
