{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/factorio-launcher/contracts/schema/factorio/factorio_source_reference.v1.schema.json",
  "title": "Factorio Source Reference",
  "type": "object",
  "required": ["schema", "kind", "provider", "source_ref", "reconstruction", "requirement", "candidate_status", "evidence_status", "evidence_identity", "provider_revision", "trust_status"],
  "properties": {
    "schema": { "const": "factorio.source_reference.v1" },
    "kind": { "type": "string" },
    "provider": { "type": "string" },
    "source_ref": { "type": "string" },
    "reconstruction": { "type": "string" },
    "requirement": { "const": "required_for_reconstruction" },
    "candidate_status": { "enum": ["unselected", "selected"] },
    "evidence_status": { "enum": ["not_observed", "inspection_required", "verified", "unavailable"] },
    "evidence_identity": { "type": "string" },
    "provider_revision": { "type": "string", "minLength": 1 },
    "trust_status": { "enum": ["unselected", "selected_unverified", "inspection_required", "verified", "unavailable"] }
  },
  "additionalProperties": false
}
