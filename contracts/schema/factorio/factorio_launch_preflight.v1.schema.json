{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/factorio-launcher/contracts/schema/factorio/factorio_launch_preflight.v1.schema.json",
  "title": "Factorio Launch Preflight",
  "type": "object",
  "required": ["schema", "command", "instance_id", "status", "executable", "args", "effective_config", "problems", "isolation_mode", "execution_class", "distribution_origin", "platform_integration", "strict_isolation_eligibility", "expected_write_domains", "forbidden_write_domains", "strict_execution_eligible", "strict_refusal_code", "started"],
  "properties": {
    "schema": { "const": "factorio.launch_preflight.v1" },
    "command": { "const": "launch_plan.preflight" },
    "instance_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["pass", "refused"] },
    "executable": { "type": "string" },
    "args": { "type": "array", "items": { "type": "string" } },
    "effective_config": {
      "type": "object",
      "required": ["config_file", "read_data", "write_data", "mod_root", "save_root", "script_output_root", "log_root"],
      "properties": {
        "config_file": { "type": "string" },
        "read_data": { "type": "string" },
        "write_data": { "type": "string" },
        "mod_root": { "type": "string" },
        "save_root": { "type": "string" },
        "script_output_root": { "type": "string" },
        "log_root": { "type": "string" }
      },
      "additionalProperties": false
    },
    "problems": { "type": "array", "items": { "type": "string" } },
    "isolation_mode": { "const": "strict" },
    "execution_class": { "enum": ["strict-isolated", "steam-integrated"] },
    "distribution_origin": { "type": "string" },
    "platform_integration": { "enum": ["steam", "none_detected", "unknown"] },
    "strict_isolation_eligibility": { "enum": ["ineligible", "candidate", "unproven", "eligible"] },
    "expected_write_domains": { "type": "array", "items": { "enum": ["instance_root"] } },
    "forbidden_write_domains": {
      "type": "array",
      "items": { "enum": ["install_root", "default_factorio_data", "steam_cloud"] }
    },
    "strict_execution_eligible": { "type": "boolean" },
    "strict_refusal_code": { "type": ["string", "null"] },
    "started": { "const": false }
  },
  "additionalProperties": false
}
