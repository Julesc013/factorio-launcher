{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/factorio-launcher/contracts/schema/factorio/factorio_installation_model.v2.schema.json",
  "title": "Factorio Installation Model",
  "type": "object",
  "required": ["schema", "command", "install_id", "current_evidence", "available_actions", "recommendations", "compatibility"],
  "properties": {
    "schema": { "const": "factorio.installation_model.v2" },
    "command": { "const": "installs.describe" },
    "install_id": { "type": "string", "minLength": 1 },
    "current_evidence": { "type": "object" },
    "available_actions": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["id", "status", "reason", "owner", "changes_install"],
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" },
          "reason": { "type": "string" },
          "owner": { "type": "string" },
          "changes_install": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "recommendations": { "type": "array", "items": { "type": "string" } },
    "compatibility": {
      "type": "object",
      "required": ["source_schema", "projection_schema", "persisted_record_rewritten", "conservative_defaults_applied", "missing_authority_default"],
      "properties": {
        "source_schema": { "const": "factorio.install_ref.v1" },
        "projection_schema": { "const": "factorio.installation_model.v2" },
        "persisted_record_rewritten": { "const": false },
        "conservative_defaults_applied": { "const": true },
        "missing_authority_default": { "const": "read_only" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
