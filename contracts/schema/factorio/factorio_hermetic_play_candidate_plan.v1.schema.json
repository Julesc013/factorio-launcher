{
  "$id": "https://facman.invalid/schema/factorio/factorio_hermetic_play_candidate_plan.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Exact frozen-policy hermetic menu Play candidate plan",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "platform": {"const": "windows"},
        "architecture": {"const": "x86_64"},
        "factorio_version": {"const": "2.0.77"},
        "distribution": {"const": "standalone_non_steam"},
        "source_authentication": {"const": "sha256_bound_to_authenticated_wube_source"},
        "filesystem": {"const": "ntfs"},
        "volume": {"const": "fixed_local"},
        "instance_ownership": {"const": "facman_owned"},
        "mod_state": {"const": "explicit_empty_lock"},
        "account_requirement": {"const": "none"},
        "credential_requirement": {"const": "none"},
        "network_requirement": {"const": "none"}
      },
      "required": ["platform", "architecture", "factorio_version", "distribution", "source_authentication", "filesystem", "volume", "instance_ownership", "mod_state", "account_requirement", "credential_requirement", "network_requirement"]
    },
    "process_binding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "executable_path_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "working_directory_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "argument_digests": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "string", "pattern": "^[a-f0-9]{64}$"}},
        "environment": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {"enum": ["SystemRoot", "TEMP", "TMP", "USERPROFILE", "WINDIR"]},
              "value_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
            },
            "required": ["name", "value_digest"]
          }
        },
        "inherit_environment": {"const": false},
        "timeout_milliseconds": {"type": "integer", "minimum": 1, "maximum": 1800000}
      },
      "required": ["executable_path_digest", "working_directory_digest", "argument_digests", "environment", "inherit_environment", "timeout_milliseconds"]
    },
    "plan_core": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema": {"const": "factorio.hermetic_play_candidate_plan.v1"},
        "canonicalization_version": {"const": "facman.sorted-json.v1"},
        "policy_id": {"const": "facman.hermetic-standalone-play.2.0.77.windows-x64.v1"},
        "policy_revision": {"const": "1"},
        "policy_digest": {"const": "6fde31f26d57e23d67c01dd598cb869a4914d11711868b46d4f817709455e7a2"},
        "candidate": {"$ref": "#/$defs/candidate"},
        "instance_id": {"type": "string", "minLength": 1},
        "machine_binding_id": {"type": "string", "minLength": 1},
        "principal_provider": {"type": "string", "minLength": 1},
        "principal_id": {"type": "string", "minLength": 1},
        "application_session_id": {"type": "string", "minLength": 1},
        "operation": {"const": "instance.play"},
        "launch_intent": {"const": "menu"},
        "isolation_mode": {"const": "hermetic"},
        "evidence_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "permit_resources": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "../common/permit_resource_binding.v1.schema.json"}},
        "provider_revisions": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"$ref": "../common/permit_provider_identity.v1.schema.json"}},
        "writable_resource_ids": {"type": "array", "minItems": 1, "maxItems": 12, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "protected_resource_ids": {"type": "array", "minItems": 18, "maxItems": 18, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "environment_revision": {"const": "factorio.menu-minimal.v1"},
        "process_binding": {"$ref": "#/$defs/process_binding"}
      },
      "required": ["schema", "canonicalization_version", "policy_id", "policy_revision", "policy_digest", "candidate", "instance_id", "machine_binding_id", "principal_provider", "principal_id", "application_session_id", "operation", "launch_intent", "isolation_mode", "evidence_digest", "permit_resources", "provider_revisions", "writable_resource_ids", "protected_resource_ids", "environment_revision", "process_binding"]
    }
  },
  "properties": {
    "schema": {"const": "factorio.hermetic_play_candidate_plan.v1"},
    "canonicalization_version": {"const": "facman.sorted-json.v1"},
    "plan_id": {"type": "string", "pattern": "^play-plan-[a-f0-9]{32}$"},
    "plan_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "plan_core": {"$ref": "#/$defs/plan_core"},
    "public_command_available": {"const": false},
    "human_verdict_recorded": {"const": false}
  },
  "required": ["schema", "canonicalization_version", "plan_id", "plan_digest", "plan_core", "public_command_available", "human_verdict_recorded"]
}
