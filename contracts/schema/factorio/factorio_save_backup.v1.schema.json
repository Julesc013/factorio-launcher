{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/factorio-launcher/contracts/schema/factorio/factorio_save_backup.v1.schema.json",
  "title": "Factorio Save Backup",
  "type": "object",
  "required": ["schema", "command", "instance_id", "save", "source_path", "destination_path", "path", "created_at", "sha1", "sha256"],
  "properties": {
    "schema": { "const": "factorio.save_backup.v1" },
    "command": { "const": "saves.backup" },
    "instance_id": { "type": "string", "minLength": 1 },
    "save": { "type": "string", "minLength": 1 },
    "source_path": { "type": "string", "minLength": 1 },
    "destination_path": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "manifest_path": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "sha1": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "additionalProperties": true
}
