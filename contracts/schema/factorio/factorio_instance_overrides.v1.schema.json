{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://facman.invalid/schema/factorio/factorio_instance_overrides.v1.schema.json",
  "title":"Factorio instance-safe profile overrides",
  "type":"object",
  "additionalProperties":false,
  "properties":{
    "schema":{"const":"factorio.instance_overrides.v1"},
    "instance_id":{"type":"string","minLength":1},
    "profile_id":{"type":"string","minLength":1},
    "values":{
      "type":"object","additionalProperties":false,
      "properties":{
        "window_mode":{"enum":["windowed","fullscreen"]},
        "graphics_quality":{"enum":["low","medium","high"]},
        "audio":{"enum":["enabled","disabled"]},
        "selection_mode":{"enum":["none","load-save","benchmark-save"]},
        "selection":{"type":"string"},
        "launch_mode":{"enum":["gui","headless-plan","benchmark-preview"]},
        "benchmark_ticks":{"type":"string","pattern":"^[0-9]+$"},
        "additional_arguments":{"type":"array","maxItems":32,"items":{"type":"string"}}
      }
    }
  },
  "required":["schema","instance_id","profile_id","values"]
}
