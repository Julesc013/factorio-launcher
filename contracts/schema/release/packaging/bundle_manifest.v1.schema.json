{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "facman.packaging.bundle_manifest.v1",
  "title": "FacMan Package Bundle Manifest",
  "type": "object",
  "required": ["schema", "artifact_id", "platform", "package_type", "components"],
  "properties": {
    "schema": { "type": "string" },
    "artifact_id": { "type": "string" },
    "platform": { "type": "string" },
    "package_type": { "type": "string" },
    "components": { "type": "array" }
  }
}
