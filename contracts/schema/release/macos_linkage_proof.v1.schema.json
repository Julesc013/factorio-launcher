{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "facman.macos_linkage_proof.v1",
  "title": "FacMan macOS Mach-O Linkage Proof",
  "type": "object",
  "required": [
    "schema", "profile_id", "runner", "architecture", "file_identity",
    "linkage_model", "deployment_target", "sdk", "dependencies",
    "allowed_dependency_prefixes", "rpath", "toolchain"
  ],
  "properties": {
    "schema": { "const": "facman.macos_linkage_proof.v1" },
    "profile_id": { "const": "macos_portable_cli_x64" },
    "runner": { "const": "macos-15-intel" },
    "architecture": { "const": "x86_64" },
    "file_identity": { "const": "Mach-O 64-bit executable x86_64" },
    "linkage_model": { "const": "project_static_system_dynamic" },
    "deployment_target": { "const": "13.0" },
    "sdk": { "type": "string", "minLength": 1 },
    "dependencies": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "allowed_dependency_prefixes": { "type": "array", "minItems": 2, "items": { "type": "string" } },
    "rpath": { "type": "null" },
    "toolchain": {
      "type": "object",
      "required": ["runner", "machine", "operating_system", "generator", "compiler", "linker", "deployment_target", "sdk"],
      "properties": {
        "runner": { "type": "string" },
        "machine": { "type": "string" },
        "operating_system": { "type": "string" },
        "generator": { "type": "string" },
        "compiler": { "type": "string" },
        "linker": { "type": "string" },
        "deployment_target": { "const": "13.0" },
        "sdk": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
