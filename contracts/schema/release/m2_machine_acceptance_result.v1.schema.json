{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "factorio.m2_machine_acceptance_result.v1.schema.json",
  "title": "M2 synthetic portable recorded MachinePass result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "work_unit", "technical_acceptance", "evidence", "validation", "human_review", "authority"],
  "properties": {
    "schema": {"const": "factorio.m2_machine_acceptance_result.v1"},
    "work_unit": {"const": "M2-WU10-AUTOMATED-ACCEPTANCE-RESULT-01"},
    "technical_acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_id", "result", "policy_revision", "runner_revision", "verifier_revision", "verified_at", "evidence_digest", "observation_sha256"],
      "properties": {
        "policy_id": {"const": "facman.m2.synthetic_portable_acceptance.v1"},
        "result": {"const": "MachinePass"},
        "policy_revision": {"$ref": "#/$defs/revision"},
        "runner_revision": {"$ref": "#/$defs/revision"},
        "verifier_revision": {"$ref": "#/$defs/revision"},
        "verified_at": {"type": "string", "format": "date-time"},
        "evidence_digest": {"$ref": "#/$defs/sha256"},
        "observation_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "evidence": {"type": "object", "minProperties": 1},
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local", "hosted"],
      "properties": {
        "local": {
          "type": "object",
          "additionalProperties": false,
          "required": ["result", "commands"],
          "properties": {
            "result": {"const": "pass"},
            "commands": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
          }
        },
        "hosted": {
          "type": "object",
          "additionalProperties": false,
          "required": ["result", "validated_revision", "pull_request", "workflows"],
          "properties": {
            "result": {"const": "pass"},
            "validated_revision": {"$ref": "#/$defs/revision"},
            "pull_request": {"type": "integer", "minimum": 1},
            "workflows": {
              "type": "array",
              "minItems": 4,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "run_id", "result"],
                "properties": {
                  "name": {"type": "string", "minLength": 1},
                  "run_id": {"type": "string", "pattern": "^[0-9]+$"},
                  "result": {"const": "success"}
                }
              }
            }
          }
        }
      }
    },
    "human_review": {
      "const": {"requirement": "not_required_for_synthetic_non_executable_lane", "result": "not_required"}
    },
    "authority": {"type": "object", "minProperties": 1}
  },
  "$defs": {
    "revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
