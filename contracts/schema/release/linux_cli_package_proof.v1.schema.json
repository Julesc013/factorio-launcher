{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "facman.linux_cli_package_proof.v1",
  "title": "FacMan Linux CLI Package Proof",
  "type": "object",
  "required": [
    "schema",
    "status",
    "profile_id",
    "target_os",
    "target_arch",
    "package_type",
    "linkage_model",
    "artifact",
    "artifact_size",
    "artifact_sha256",
    "source_revisions",
    "toolchain",
    "dynamic_dependencies",
    "rpath",
    "runpath",
    "checks",
    "required_skips",
    "signed",
    "published",
    "claim_scope"
  ],
  "properties": {
    "schema": { "const": "facman.linux_cli_package_proof.v1" },
    "status": { "const": "pass" },
    "profile_id": { "const": "linux_portable_cli_x64" },
    "target_os": { "const": "linux" },
    "target_arch": { "const": "x64" },
    "package_type": { "const": "tarball" },
    "linkage_model": { "const": "project_static_system_dynamic" },
    "artifact": { "type": "string", "pattern": "\\.tar\\.gz$" },
    "artifact_size": { "type": "integer", "minimum": 1 },
    "artifact_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "source_revisions": {
      "type": "object",
      "required": ["factorio_launcher", "universal_launcher", "universal_setup"],
      "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
    },
    "toolchain": { "type": "object" },
    "dynamic_dependencies": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "rpath": { "type": "null" },
    "runpath": { "type": "null" },
    "checks": { "type": "array", "minItems": 10, "items": { "type": "string" } },
    "required_skips": { "const": 0 },
    "signed": { "const": false },
    "published": { "const": false },
    "claim_scope": { "const": "ubuntu-24.04-x64-runner-package-preview" }
  },
  "additionalProperties": false
}
