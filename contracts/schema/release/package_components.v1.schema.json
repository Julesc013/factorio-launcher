{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "facman.package_components.v1",
  "title": "FacMan Built Package Components",
  "type": "object",
  "required": ["schema", "components"],
  "properties": {
    "schema": { "const": "facman.package_components.v1" },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "source_target",
          "destination",
          "kind",
          "runtime_role",
          "sha256",
          "size"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "source_target": { "type": "string", "minLength": 1 },
          "destination": { "type": "string", "minLength": 1 },
          "container_destination": { "type": "string", "minLength": 1 },
          "kind": {
            "enum": ["frontend", "daemon", "runtime_library", "contracts", "content", "support_metadata"]
          },
          "runtime_role": {
            "enum": ["runtime_required", "compatibility_reference", "documentation_only"]
          },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "size": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
