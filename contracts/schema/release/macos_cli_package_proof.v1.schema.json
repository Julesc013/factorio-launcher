{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "facman.macos_cli_package_proof.v1",
  "title": "FacMan macOS CLI Package Proof",
  "type": "object",
  "required": [
    "schema", "status", "profile_id", "target_os", "target_arch",
    "package_type", "linkage_model", "deployment_target", "artifact",
    "artifact_size", "artifact_sha256", "provenance_sha256",
    "source_revisions", "toolchain", "dynamic_dependencies", "rpath",
    "checks", "required_skips", "signed", "notarized", "published",
    "claim_scope"
  ],
  "properties": {
    "schema": { "const": "facman.macos_cli_package_proof.v1" },
    "status": { "const": "pass" },
    "profile_id": { "const": "macos_portable_cli_x64" },
    "target_os": { "const": "macos" },
    "target_arch": { "const": "x64" },
    "package_type": { "const": "tarball" },
    "linkage_model": { "const": "project_static_system_dynamic" },
    "deployment_target": { "const": "13.0" },
    "artifact": { "type": "string", "pattern": "\\.tar\\.gz$" },
    "artifact_size": { "type": "integer", "minimum": 1 },
    "artifact_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "provenance_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "source_revisions": {
      "type": "object",
      "required": ["factorio_launcher", "universal_launcher", "universal_setup"],
      "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
    },
    "toolchain": { "type": "object", "minProperties": 8 },
    "dynamic_dependencies": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "rpath": { "type": "null" },
    "checks": { "type": "array", "minItems": 15, "uniqueItems": true, "items": { "type": "string" } },
    "required_skips": { "const": 0 },
    "signed": { "const": false },
    "notarized": { "const": false },
    "published": { "const": false },
    "claim_scope": { "const": "macos-15-intel-x64-macos-13-package-preview" }
  },
  "additionalProperties": false
}
