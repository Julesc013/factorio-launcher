{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "facman.spdx_document.v2.3",
  "title": "FacMan Package SPDX 2.3 Document",
  "type": "object",
  "required": [
    "spdxVersion",
    "dataLicense",
    "SPDXID",
    "name",
    "documentNamespace",
    "creationInfo",
    "packages",
    "relationships"
  ],
  "properties": {
    "spdxVersion": { "const": "SPDX-2.3" },
    "dataLicense": { "const": "CC0-1.0" },
    "SPDXID": { "const": "SPDXRef-DOCUMENT" },
    "name": { "type": "string", "minLength": 1 },
    "documentNamespace": { "type": "string", "pattern": "^https://github.com/Julesc013/factorio-launcher/spdx/" },
    "creationInfo": {
      "type": "object",
      "required": ["created", "creators", "comment"],
      "properties": {
        "created": { "type": "string", "minLength": 20 },
        "creators": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "comment": { "const": "Timestamp policy: source_commit_utc; unsigned build evidence." }
      },
      "additionalProperties": false
    },
    "packages": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "SPDXID",
          "name",
          "versionInfo",
          "downloadLocation",
          "filesAnalyzed",
          "licenseConcluded",
          "licenseDeclared",
          "copyrightText",
          "packageComment"
        ],
        "properties": {
          "SPDXID": { "type": "string", "pattern": "^SPDXRef-Package-" },
          "name": { "type": "string", "minLength": 1 },
          "versionInfo": { "type": "string", "minLength": 1 },
          "downloadLocation": { "type": "string", "minLength": 1 },
          "filesAnalyzed": { "const": false },
          "licenseConcluded": { "type": "string", "minLength": 1 },
          "licenseDeclared": { "type": "string", "minLength": 1 },
          "copyrightText": { "type": "string", "minLength": 1 },
          "packageComment": { "type": "string", "minLength": 1 },
          "externalRefs": { "type": "array", "items": { "type": "object" } }
        },
        "additionalProperties": false
      }
    },
    "relationships": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["spdxElementId", "relationshipType", "relatedSpdxElement"],
        "properties": {
          "spdxElementId": { "type": "string" },
          "relationshipType": { "type": "string" },
          "relatedSpdxElement": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
