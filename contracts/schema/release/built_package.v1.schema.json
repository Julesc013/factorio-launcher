{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "facman.built_package.v1",
  "title": "FacMan Built Package Manifest",
  "type": "object",
  "required": [
    "schema",
    "profile_id",
    "lane",
    "target_os",
    "target_arch",
    "package_type",
    "entrypoint",
    "linkage_model",
    "release_profile",
    "package_manifest",
    "workspace_lock",
    "source_revision",
    "proof_baseline_revision",
    "universal_launcher_revision",
    "universal_setup_revision",
    "artifact_level",
    "signed",
    "published",
    "source_dirty",
    "python_runtime",
    "bundles_factorio_binaries"
  ],
  "properties": {
    "schema": { "const": "facman.built_package.v1" },
    "profile_id": { "type": "string", "minLength": 1 },
    "lane": { "type": "string", "minLength": 1 },
    "target_os": { "enum": ["windows", "portable"] },
    "target_arch": { "const": "x64" },
    "package_type": { "enum": ["portable_zip"] },
    "entrypoint": { "type": "string", "minLength": 1 },
    "linkage_model": {
      "enum": ["static_first", "static_first_with_reference_components", "compatibility_bundle"]
    },
    "release_profile": { "type": "string", "minLength": 1 },
    "package_manifest": { "type": "string", "minLength": 1 },
    "workspace_lock": { "const": "release/index/workspace_lock.v1.toml" },
    "source_revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "proof_baseline_revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "universal_launcher_revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "universal_setup_revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "artifact_level": { "const": "built-artifact" },
    "signed": { "const": false },
    "published": { "const": false },
    "source_dirty": { "type": "boolean" },
    "python_runtime": { "const": false },
    "bundles_factorio_binaries": { "const": false }
  },
  "additionalProperties": false
}
