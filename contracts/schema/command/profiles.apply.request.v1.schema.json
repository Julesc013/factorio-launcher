{
  "$id": "https://facman.invalid/schema/command/profiles.apply.request.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "additional_arguments": {
      "items": {
        "type": "string"
      },
      "maxItems": 256,
      "type": "array"
    },
    "audio": {
      "type": "string"
    },
    "benchmark_ticks": {
      "type": "string"
    },
    "graphics_quality": {
      "type": "string"
    },
    "instance_id": {
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "type": "string"
    },
    "launch_mode": {
      "type": "string"
    },
    "profile_id": {
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "type": "string"
    },
    "selection": {
      "type": "string"
    },
    "selection_mode": {
      "type": "string"
    },
    "window_mode": {
      "type": "string"
    }
  },
  "required": [
    "instance_id",
    "profile_id"
  ],
  "title": "profiles.apply request",
  "type": "object"
}
