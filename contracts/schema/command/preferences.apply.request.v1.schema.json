{
  "$id": "https://facman.invalid/schema/command/preferences.apply.request.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "backup_destination": {
      "type": "string"
    },
    "backup_keep_last": {
      "pattern": "^(?:[0-9]{1,6}|1000000)$",
      "type": "string"
    },
    "command_timeout_seconds": {
      "pattern": "^(?:[0-9]{1,6}|1000000)$",
      "type": "string"
    },
    "default_instance_template": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "type": "string"
    },
    "default_launch_profile": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "type": "string"
    },
    "discovery_providers": {
      "items": {
        "type": "string"
      },
      "maxItems": 256,
      "type": "array"
    },
    "discovery_roots": {
      "items": {
        "type": "string"
      },
      "maxItems": 256,
      "type": "array"
    },
    "display_color_policy": {
      "enum": [
        "auto",
        "always",
        "never"
      ],
      "type": "string"
    },
    "preferred_transport": {
      "enum": [
        "direct",
        "process",
        "daemon"
      ],
      "type": "string"
    },
    "preferred_workspace": {
      "type": "string"
    },
    "tui_page_size": {
      "pattern": "^(?:[0-9]{1,6}|1000000)$",
      "type": "string"
    }
  },
  "title": "preferences.apply request",
  "type": "object"
}
