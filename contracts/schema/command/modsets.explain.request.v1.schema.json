{
  "$id": "https://facman.invalid/schema/command/modsets.explain.request.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "disabled_mods": {
      "items": {
        "type": "string"
      },
      "maxItems": 256,
      "type": "array"
    },
    "enabled_mods": {
      "items": {
        "type": "string"
      },
      "maxItems": 256,
      "type": "array"
    },
    "instance_id": {
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "type": "string"
    },
    "maximum_backtracks": {
      "pattern": "^(?:[0-9]{1,6}|1000000)$",
      "type": "string"
    },
    "maximum_elapsed_ms": {
      "pattern": "^(?:[0-9]{1,6}|1000000)$",
      "type": "string"
    },
    "maximum_explanation_nodes": {
      "pattern": "^(?:[0-9]{1,6}|1000000)$",
      "type": "string"
    },
    "maximum_graph_edges": {
      "pattern": "^(?:[0-9]{1,6}|1000000)$",
      "type": "string"
    },
    "maximum_packages": {
      "pattern": "^(?:[0-9]{1,6}|1000000)$",
      "type": "string"
    },
    "maximum_solver_states": {
      "pattern": "^(?:[0-9]{1,6}|1000000)$",
      "type": "string"
    },
    "maximum_versions_per_package": {
      "pattern": "^(?:[0-9]{1,6}|1000000)$",
      "type": "string"
    },
    "version_preferences": {
      "items": {
        "type": "string"
      },
      "maxItems": 256,
      "type": "array"
    }
  },
  "required": [
    "instance_id"
  ],
  "title": "modsets.explain request",
  "type": "object"
}
