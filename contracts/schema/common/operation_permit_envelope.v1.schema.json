{
  "$id": "https://facman.invalid/schema/common/operation_permit_envelope.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Authenticated operation permit envelope",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "common.operation_permit_envelope.v1"},
    "claims": {"$ref": "operation_permit_claims.v1.schema.json"},
    "claims_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "authenticator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "algorithm": {"const": "hmac-sha256.process.v1"},
        "value": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      },
      "required": ["algorithm", "value"]
    }
  },
  "required": ["schema", "claims", "claims_digest", "authenticator"]
}
