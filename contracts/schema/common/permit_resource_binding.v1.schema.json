{
  "$id": "https://facman.invalid/schema/common/permit_resource_binding.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Exact operation permit resource binding",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "resource_kind": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{1,63}$"},
    "role": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{1,63}$"},
    "logical_id": {"type": "string", "minLength": 1, "maxLength": 256, "not": {"pattern": "\\*"}},
    "current_identity_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "owning_provider": {"$ref": "permit_provider_identity.v1.schema.json"},
    "permitted_effects": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["workspace_read", "workspace_write", "process_execute", "network_read", "network_write", "credential_read", "release_sign", "release_publish", "setup_preview", "setup_mutation"]}
    }
  },
  "required": ["resource_kind", "role", "logical_id", "current_identity_digest", "owning_provider", "permitted_effects"]
}
