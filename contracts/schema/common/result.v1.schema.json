{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/factorio-launcher/contracts/schema/common/result.v1.schema.json",
  "title": "Result",
  "type": "object",
  "required": ["schema_version", "status"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["ok", "warning", "blocked", "refused", "error"] },
    "message": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
