{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://julesc013.github.io/factorio-launcher/contracts/schema/common/effects.v1.schema.json",
  "title": "FacMan Command Effects",
  "type": "object",
  "required": ["schema", "effects", "risk_tiers"],
  "properties": {
    "schema": { "const": "common.effects.v1" },
    "effects": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "risk_tiers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["label", "severity"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["info", "warning", "danger", "blocked"] },
          "description": { "type": "string" }
        }
      }
    },
    "effect_risk": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
