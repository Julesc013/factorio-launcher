{
  "$id": "https://facman.invalid/schema/common/operation_permit_claims.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Canonical short-lived operation permit claims",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "closedEffects": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["workspace_read", "workspace_write", "process_execute", "network_read", "network_write", "credential_read", "release_sign", "release_publish", "setup_preview", "setup_mutation"]}
    }
  },
  "properties": {
    "schema": {"const": "common.operation_permit_claims.v1"},
    "canonicalization_version": {"const": "facman.sorted-json.v1"},
    "permit_id": {"type": "string", "pattern": "^permit-[a-f0-9]{32}$"},
    "issuer_session_id": {"type": "string", "pattern": "^session-[a-f0-9]{32}$"},
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{2,127}$"},
        "launch_intent": {"type": ["string", "null"], "minLength": 1, "maxLength": 64},
        "isolation_mode": {"type": ["string", "null"], "minLength": 1, "maxLength": 64}
      },
      "required": ["kind", "launch_intent", "isolation_mode"]
    },
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "plan_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "plan_digest": {"$ref": "#/$defs/sha256"}
      },
      "required": ["plan_id", "plan_digest"]
    },
    "audience": {"$ref": "permit_provider_identity.v1.schema.json"},
    "resources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {"$ref": "permit_resource_binding.v1.schema.json"}
    },
    "effects": {"$ref": "#/$defs/closedEffects"},
    "required_capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9._-]{2,127}$"}
    },
    "machine_binding_id": {"type": "string", "minLength": 1, "maxLength": 160},
    "principal": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider_id": {"type": "string", "pattern": "^[a-z][a-z0-9.-]{2,127}$"},
        "principal_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "application_session_id": {"type": "string", "minLength": 1, "maxLength": 160}
      },
      "required": ["provider_id", "principal_id", "application_session_id"]
    },
    "evidence_digest": {"$ref": "#/$defs/sha256"},
    "policy": {"$ref": "permit_policy_binding.v1.schema.json"},
    "provider_revisions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {"$ref": "permit_provider_identity.v1.schema.json"}
    },
    "issued_at_unix_seconds": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
    "not_before_unix_seconds": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
    "expires_at_unix_seconds": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
    "nonce": {"type": "string", "pattern": "^nonce-[a-f0-9]{32}$"}
  },
  "required": [
    "schema", "canonicalization_version", "permit_id", "issuer_session_id",
    "operation", "plan", "audience", "resources", "effects",
    "required_capabilities", "machine_binding_id", "principal",
    "evidence_digest", "policy", "provider_revisions",
    "issued_at_unix_seconds", "not_before_unix_seconds",
    "expires_at_unix_seconds", "nonce"
  ]
}
